# Copy this file to ".env" and paste your key in. Never share or commit the real .env.
# Free key: https://console.cloud.google.com  ->  enable "YouTube Data API v3"  ->  Create credentials -> API key
YOUTUBE_API_KEY=your_key_here

# Apify token for TikTok / Instagram / RedNote (free tier, no card needed):
# apify.com -> Settings -> Integrations -> API tokens -> copy
APIFY_TOKEN=your_apify_token_here
